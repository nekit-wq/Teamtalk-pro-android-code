<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UserPropActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/user_nickname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dividerColor"
            android:layout_marginVertical="8dp" />

        <TextView
            android:id="@+id/user_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:padding="4dp" />

        <TextView
            android:id="@+id/user_userid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:padding="4dp" />

        <TextView
            android:id="@+id/user_statusmsg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:padding="4dp" />

        <TextView
            android:id="@+id/user_clientname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/textSecondary"
            android:padding="4dp" />

        <TextView
            android:id="@+id/user_ipaddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/textSecondary"
            android:padding="4dp" />

        <TextView
            android:id="@+id/user_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/textSecondary"
            android:padding="4dp"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dividerColor"
            android:layout_marginVertical="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/user_prop_title_voice_volume"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp">

            <SeekBar
                android:id="@+id/user_vol_voiceSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:contentDescription="@string/voicevolume" />

            <Button
                android:id="@+id/defVoiceVolBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="13sp" />
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_mutevoiceSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_mute_voice" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dividerColor"
            android:layout_marginVertical="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/user_prop_title_media_volume"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp">

            <SeekBar
                android:id="@+id/user_vol_mediaSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:contentDescription="@string/mediavolume" />

            <Button
                android:id="@+id/defMfVolBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="13sp" />
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_mutemediaSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_mute_media" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dividerColor"
            android:layout_marginVertical="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_subscribetxtmsgSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_subscribe_txtmsg" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_subscribechanmsgSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_subscribe_chanmsg" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_subscribebcastmsgSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_subscribe_bcastmsg" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_subscribevoiceSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_subscribe_voice" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_subscribevidSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_subscribe_vid" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_subscribedeskSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_subscribe_desk" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_subscribemediaSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_subscribe_media" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dividerColor"
            android:layout_marginVertical="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_subscribeintercepttxtmsgSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_subscribe_intercept_txtmsg" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_subscribeinterceptchanmsgSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_subscribe_intercept_chanmsg" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_subscribeinterceptvoiceSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_subscribe_intercept_voice" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_subscribeinterceptvidSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_subscribe_intercept_vid" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_subscribeinterceptdeskSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_subscribe_intercept_desk" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_subscribeinterceptmediaSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_subscribe_intercept_media" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dividerColor"
            android:layout_marginVertical="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_transmitvoiceSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_transmit_voice" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_transmitvidSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_transmit_vid" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_transmitdeskSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_transmit_desk" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_transmitmediaSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_transmit_media" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/user_transmitchanmsgSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="@string/user_prop_title_transmit_chanmsg" />

    </LinearLayout>

</ScrollView>
