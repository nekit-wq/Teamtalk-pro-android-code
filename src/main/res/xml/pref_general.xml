<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android" >

    <EditTextPreference
		android:key="nickname_text"
		android:title="@string/pref_title_nickname"
		android:selectAllOnFocus="true"
		android:singleLine="true" />

    <EditTextPreference
		android:key="statusmsg_text"
		android:title="@string/pref_title_statusmsg"
		android:selectAllOnFocus="true"
		android:singleLine="true" />

	<CheckBoxPreference
		android:defaultValue="false"
		android:key="gender_checkbox"
		android:title="@string/pref_title_gender"
		android:summary="@string/pref_summary_gender" />

	<CheckBoxPreference
		android:key="bearwareid_checkbox"
		android:defaultValue="false"
		android:title="@string/pref_title_bearwareid"
		android:summary="@string/pref_summary_bearwareid" />

    <CheckBoxPreference
		android:key="movetalk_checkbox"
		android:defaultValue="true"
		android:title="@string/pref_title_move_talking"
		android:summary="@string/pref_summary_move_talking" />

    <CheckBoxPreference
		android:key="showusernames_checkbox"
		android:defaultValue="false"
		android:title="@string/pref_title_show_usernames"
		android:summary="@string/pref_summary_show_usernames" />

    <CheckBoxPreference
		android:key="vibrate_checkbox"
		android:defaultValue="true"
		android:title="@string/pref_title_vibrate" />

    <CheckBoxPreference
		android:key="proximity_sensor_checkbox"
		android:defaultValue="false"
		android:title="@string/pref_title_proximity_sensor" />

    <CheckBoxPreference
		android:key="keep_screen_on_checkbox"
		android:defaultValue="false"
		android:title="@string/pref_title_keep_screen_on" />

    <CheckBoxPreference
		android:key="show_log_messages"
		android:defaultValue="true"
		android:title="@string/pref_show_log_messages" />

    <EditTextPreference
        android:key="clientname_text"
        android:title="@string/pref_title_clientname"
        android:summary="@string/pref_summary_clientname"
        android:selectAllOnFocus="true"
        android:singleLine="true" />

    <ListPreference
        android:key="theme_preference"
        android:title="@string/pref_title_theme"
        android:summary="@string/pref_summary_theme"
        android:entries="@array/theme_entries"
        android:entryValues="@array/theme_values"
        android:defaultValue="auto" />

</PreferenceScreen>
