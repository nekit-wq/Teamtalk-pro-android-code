<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".WebLoginActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/weblogin_prop_title_web_login_id"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/createbearwareidbutton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/weblogin_prop_title_create_web_login_id"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/resetbearwareidbutton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/weblogin_prop_title_reset_web_login_id"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/weblogin_prop_title_bearwareid"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/bearwareidedit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="text"
        android:singleLine="true"
        android:hint="@string/bwidlab"
        android:autofillHints="username"
        android:background="@drawable/edit_text_background"
        android:padding="10dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/bearwarepasswdlabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/weblogin_prop_title_bearwarepasswd"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/bearwarepasswdedit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textPassword"
        android:hint="@string/bwpswlab"
        android:autofillHints="password"
        android:background="@drawable/edit_text_background"
        android:padding="10dp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/bearwareloginbutton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/weblogin_prop_title_login" />

</LinearLayout>
