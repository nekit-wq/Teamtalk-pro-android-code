<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/item_textmsg_srvinfo"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@color/srvInfoBackground">

    <TextView
        android:id="@+id/srvname_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/message_text"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/srvInfoTitleColor" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/srvmotd_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/message_text"
            android:textSize="13sp"
            android:textColor="@color/srvInfoTextColor" />

        <TextView
            android:id="@+id/logtime_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/srvInfoTimeColor"
            android:text="@string/time_date" />
    </LinearLayout>
</LinearLayout>
